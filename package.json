{
  "name": "pit-boss-bot",
  "version": "0.0.1",
  "description": "A Discord bot for the University Of Waterloo Poker Studies Club",
  "main": "dist/src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rm -r dist",
    "build": "tsc --build",
    "start": "npm run clean && npm run build && node dist/src/scripts/deployCommands.js && node dist/src/index.js",
    "startNoRegistration": "npm run clean && npm run build && node dist/src/index.js",
    "startNoClean": "npm run build && node dist/src/index.js",

    "registerCommands": "node dist/src/scripts/deployCommands.js",
    "dbUp": "(cd ./sqliteMigration; npx sequelize-cli db:migrate)",
    "dbDown": "(cd ./sqliteMigration; npx sequelize-cli db:migrate:undo)",
    "createMigration": "(cd ./sqliteMigration; npx sequelize-cli migration:generate --name $NAME)",

    "cleanDB": "npm run build && node dist/src/devScripts/cleanDB.js",
    "populate": "npm run build && node dist/src/devScripts/populatePostgres.js"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uwpokerclub/pit-boss-bot.git"
  },
  "author": "University of Waterloo Poker Studies Club Development Team (uwaterloopoker@gmail.com)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/uwpokerclub/pit-boss-bot/issues"
  },
  "homepage": "https://github.com/uwpokerclub/pit-boss-bot#readme",
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/eslint__js": "^8.42.3",
    "@types/eslint-config-prettier": "^6.11.3",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.9.0",
    "prettier": "3.8.1",
    "sequelize-cli": "^6.6.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "axios": "^1.13.6",
    "discord.js": "^14.25.1",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7"
  }
}
